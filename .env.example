# ============================================================
# Dubai Real Estate Analytics Platform - environment template
# Copy to .env and fill in. The pipeline reads this file.
# ============================================================

# Neon (or any) PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Data source switch. "xlsx" reads local Dubai Pulse files.
# Set to "api" once the DLD API key arrives - pipeline auto-switches.
DATA_SOURCE=xlsx

# DLD API (phase 2). Leave blank until the key arrives.
DLD_API_KEY=
DLD_API_BASE=https://api.dubailand.gov.ae

# Local input files (used when DATA_SOURCE=xlsx)
TRANSACTIONS_XLSX=input/Real_Estate_Transactions_2026-06-23.xlsx
PROJECTS_XLSX=input/projects_2026-05-21_02-07-22_1.xlsx

# Scheduler: hour of day (0-23) for the daily refresh
REFRESH_HOUR=3

# MLflow tracking directory
MLFLOW_TRACKING_URI=sqlite:///artifacts/mlflow.db

# Logging
LOG_LEVEL=INFO

# --- DDA iPaaS live API (projects dataset) - set DATA_SOURCE=api to activate ---
DDA_TOKEN_URL=
DDA_PROJECTS_URL=
DDA_CLIENT_ID=
DDA_CLIENT_SECRET=
DDA_SECURITY_APP_ID=
DDA_APPLICATION_ID=
DDA_SCOPE=
DDA_ENV=STG
